{
  "name": "vibe-research",
  "version": "1.0.0",
  "description": "Vibe Research - AI-powered research assistant for Zotero",
  "main": "./out/main/index.js",
  "author": "ZoteroOfMine",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "pnpm build && electron-builder --win --config electron-builder.yml",
    "build:mac": "pnpm build && electron-builder --mac --config electron-builder.yml",
    "build:linux": "pnpm build && electron-builder --linux --config electron-builder.yml",
    "build:all": "pnpm build && electron-builder --win --mac --linux --config electron-builder.yml"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.8"
  }
}
